        "cmd": "./coven-code",
        "args": [
          "acp"
        ]
      },
      "linux-x86_64": {
        "archive": "https://github.com/OpenCoven/coven-code/releases/download/v0.0.7/coven-code-linux-x86_64.tar.gz",
